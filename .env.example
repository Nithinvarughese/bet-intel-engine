# Copy this file to `.env` and fill in values (`.env` is gitignored).

# PostgreSQL (SQLAlchemy URL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/football_analytics

# API-Football / API-Sports (required for ingest.py to download fixtures)
# Dashboard (direct): https://dashboard.api-football.com — use:
FOOTBALL_API_KEY=
# If you subscribed on RapidAPI instead, use this and leave FOOTBALL_API_KEY empty:
# RAPIDAPI_KEY=
