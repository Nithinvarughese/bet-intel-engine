# Streamlit Community Cloud: Settings → Secrets → paste as TOML (do not commit real values).
# Copy shape only; keep real secrets in the Cloud UI or local `.streamlit/secrets.toml` (gitignored).

# Preferred: root key (Streamlit also mirrors this into the process environment).
DATABASE_URL = "postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# Also supported (nested sections are NOT exported to os.environ; the app reads them via st.secrets):
# [database]
# url = "postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"
